{
  "name": "rmsv3-functions",
  "description": "Cloud Functions for Rental Management System v3",
  "scripts": {
    "build": "tsc",
    "build:watch": "tsc --watch",
    "serve": "npm run build && firebase emulators:start --only functions",
    "shell": "npm run build && firebase functions:shell",
    "start": "npm run shell",
    "deploy": "firebase deploy --only functions",
    "logs": "firebase functions:log"
  },
  "engines": {
    "node": "20"
  },
  "main": "lib/index.js",
  "dependencies": {
    "@genkit-ai/googleai": "^1.28.0",
    "@genkit-ai/vertexai": "^1.30.1",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "firebase-admin": "^12.0.0",
    "firebase-functions": "^6.0.0",
    "genkit": "^1.30.1",
    "helmet": "^7.1.0",
    "joi": "^17.11.0",
    "nodemailer": "^6.9.7"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/nodemailer": "^6.4.14",
    "typescript": "^4.9.0"
  },
  "private": true
}
